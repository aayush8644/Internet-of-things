
import time
import math
from gpiozero import PWMLED
from signal import pause

# Initialize the LED on BCM GPIO 17 using PWM mode
# Default frequency is 100Hz, which provides flicker-free dimming
led = PWMLED(17)

print("Starting PWM LED control on GPIO 17... Press Ctrl+C to stop.\n")

try:
    # We use a running counter to generate a smooth sine wave
    step = 0
    
    while True:
        # math.sin outputs values from -1 to 1. 
        # We transform it to output values strictly from 0.0 (off) to 1.0 (full brightness)
        brightness = (math.sin(step) + 1.0) / 2.0
        
        # Apply the value to the PWM duty cycle
        led.value = brightness
        
        # Increment the wave speed slightly
        step += 0.05
        
        # Tiny delay to control the speed of the breathing effect
        time.sleep(0.02)

except KeyboardInterrupt:
    print("\nShutting down PWM signal...")
    # PWMLED sets the duty cycle back to 0 automatically upon exit


