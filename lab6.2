import os
import sqlite3
import datetime
import time
import board
import adafruit_dht


# Configuration Constants
DB_NAME = "sensor_data.db"
DHT_PIN = board.D18       # Standard BCM Pin 18 (Physical Pin 12)
LOG_INTERVAL = 5.0        # Time delay between successful readings in seconds
CHART_IMAGE_NAME = "sensor_trends.png"


def setup_database():
    """Initializes the SQLite database and creates the readings table if it doesn't exist."""
    print(f"Initializing database: {DB_NAME}...")
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS readings (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            timestamp TEXT NOT NULL,
            temperature REAL,
            humidity REAL
        )
    ''')
    conn.commit()
    conn.close()
    print("Database table ready.")


def insert_reading(temp, hum):
    """Inserts a single sensor reading row into the database with a current timestamp."""
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    cursor.execute(
        "INSERT INTO readings (timestamp, temperature, humidity) VALUES (?, ?, ?)",
        (timestamp, temp, hum)
    )
    conn.commit()
    conn.close()


def generate_visualization():
    """
    Queries the database for historical logs, compiles the trends,
    and generates a dual-axis Matplotlib line plot saved as a PNG image.
    """
    print("\nExtracting database records for visualization...")
   
    # Check if database file exists and has records
    if not os.path.exists(DB_NAME):
        print("Error: No database file found to plot.")
        return


    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute("SELECT timestamp, temperature, humidity FROM readings ORDER BY id ASC")
    rows = cursor.fetchall()
    conn.close()


    if len(rows) < 2:
        print("Warning: Insufficient data logged to generate a line trend. Collect at least 2 points!")
        return


    # Unpack columns into lists
    timestamps = [datetime.datetime.strptime(r[0], "%Y-%m-%d %H:%M:%S") for r in rows]
    temperatures = [r[1] for r in rows]
    humidities = [r[2] for r in rows]


    # Try importing matplotlib on-demand
    try:
        import matplotlib.pyplot as plt
        import matplotlib.dates as mdates
    except ImportError:
        print("Error: 'matplotlib' is not installed in this environment.")
        print("Please install it with: pip install matplotlib")
        return


    print("Generating dual-axis line chart...")
    fig, ax1 = plt.subplots(figsize=(10, 5))


    # Plot Temperature on Left Y-axis (Red)
    color = 'tab:red'
    ax1.set_xlabel('Timestamp (Time of Reading)')
    ax1.set_ylabel('Temperature (�C)', color=color)
    ax1.plot(timestamps, temperatures, color=color, linewidth=2, label='Temperature (�C)')
    ax1.tick_params(axis='y', labelcolor=color)
    ax1.grid(True, linestyle='--', alpha=0.5)


    # Instantiate a second axes that shares the same x-axis for Humidity (Blue)
    ax2 = ax1.twinx()  
    color = 'tab:blue'
    ax2.set_ylabel('Humidity (%)', color=color)
    ax2.plot(timestamps, humidities, color=color, linewidth=2, linestyle='--', label='Humidity (%)')
    ax2.tick_params(axis='y', labelcolor=color)


    # Format the Time labels on X-axis cleanly
    fig.autofmt_xdate()
    ax1.xaxis.set_major_formatter(mdates.DateFormatter('%H:%M:%S'))


    plt.title('DHT11 Environment Sensor Trends Over Time')
    fig.tight_layout()  # Adjust layout to prevent clipping


    # Save to file (ideal for headless terminal operation)
    plt.savefig(CHART_IMAGE_NAME, dpi=150)
    plt.close()
    print(f"Success! Historical chart saved as: {CHART_IMAGE_NAME}")


def main():
    # Setup database
    setup_database()
   
    # Initialize the DHT11 sensor hardware
    dht_device = adafruit_dht.DHT11(DHT_PIN)
   
    print(f"\nStarting logging session (Logging interval: {LOG_INTERVAL}s).")
    print("Press Ctrl+C to stop logging and generate the visual trend graph.\n")
   
    try:
        while True:
            try:
                temp = dht_device.temperature
                hum = dht_device.humidity
               
                if temp is not None and hum is not None:
                    insert_reading(temp, hum)
                    timestamp = datetime.datetime.now().strftime("%H:%M:%S")
                    print(f"[{timestamp}] Logged to DB -> Temp: {temp:.1f}�C | Hum: {hum:.1f}%")
                    time.sleep(LOG_INTERVAL)
                   
            except RuntimeError:
                # The DHT11 is timing-sensitive; drop occasional bit glitches silently
                time.sleep(0.5)
                continue
            except Exception as e:
                dht_device.exit()
                raise e


    except KeyboardInterrupt:
        print("\nLogging stopped by student.")
    finally:
        # Cleanup sensor hardware connection safely
        dht_device.exit()
       
        # Ask if the student wants to generate the visualization chart
        generate_visualization()
        print("System shutdown clean. Goodbye!")


if __name__ == "__main__":
    main()









