    try:
        conn = sqlite3.connect(DB_NAME)
        cursor = conn.cursor()
        timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        cursor.execute(
            "INSERT INTO mqtt_readings (timestamp, device_id, temperature, humidity) VALUES (?, ?, ?, ?)",
            (timestamp, device_id, temp, hum)
        )
        conn.commit()
        conn.close()
        print(f" -> [Logged to DB] Device: {device_id} | Temp: {temp:.1f}�C | Hum: {hum:.1f}%")
    except Exception as e:
        print(f"[DATABASE ERROR] Could not save transaction record: {e}")


